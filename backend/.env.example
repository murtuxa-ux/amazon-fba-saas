# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/ecomera_fba

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72

# Keepa API
KEEPA_API_KEY=

# Stripe (Phase 2 - leave blank for now)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,https://amazon-fba-saas.vercel.app
